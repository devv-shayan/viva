# Server-only OpenAI key. Never expose this value in browser code.
OPENAI_API_KEY=your_openai_api_key

# Cloudflare account and D1 database used by the classroom platform.
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id
CLOUDFLARE_API_TOKEN=your_d1_and_r2_api_token

# Private R2 bucket for original assignment uploads.
CLOUDFLARE_R2_BUCKET=your_private_bucket_name
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
